config interface 'loopback'
	option device 'lo'
	option proto 'static'
	list ipaddr '127.0.0.1/8'

config globals 'globals'
	option dhcp_default_duid '0004c2eaffc3da37438fbb740bb4aa23e09c'
	option ula_prefix 'fd16:8be0:d6f5::/48'
	option packet_steering '1'

config device
	option name 'br-lan'
	option type 'bridge'
	list ports 'eth0.31'

config interface 'lan'
	option device 'br-lan'
	option proto 'static'
	list ipaddr '11.31.0.1/24'
	option multipath 'off'
	option delegate '1'
	list ip6addr 'fd16:8be0:d6f5::1/64'

config interface 'wan'
	option device 'eth0'
	option proto 'static'
	option ipaddr '11.0.0.31'
	option netmask '255.255.255.0'
	option gateway '11.0.0.1'
	option multipath 'off'
	list dns '11.0.0.1'
	option delegate '0'

config interface 'wan6'
	option proto 'dhcpv6'
	option device 'eth0'
	option reqaddress 'try'
	option reqprefix 'no'
	option norelease '1'
	option peerdns '0'
	option multipath 'off'
	option delegate '0'